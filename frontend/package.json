{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "cra-template": "1.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.6.3",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "craco start",
    "prebuild": "node scripts/build-data.js",
    "build": "craco build",
    "postbuild": "react-snap",
    "test": "craco test",
    "eject": "react-scripts eject"
  },
  "reactSnap": {
    "include": [
      "/",
      "/uk",
      "/uk/first-role",
      "/licensing-route",
      "/usa",
      "/canada",
      "/australia",
      "/training-programs",
      "/training-programs/uk",
      "/training-programs/usa",
      "/training-programs/canada",
      "/training-programs/australia",
      "/internships-residencies",
      "/internships-residencies/uk",
      "/internships-residencies/uk/college",
      "/internships-residencies/uk/university",
      "/internships-residencies/uk/corporate",
      "/internships-residencies/europe",
      "/internships-residencies/europe/college",
      "/internships-residencies/europe/university",
      "/internships-residencies/europe/corporate",
      "/internships-residencies/north-america",
      "/internships-residencies/worldwide",
      "/postgraduate-certificates",
      "/postgraduate-certificates/uk",
      "/postgraduate-certificates/usa",
      "/postgraduate-certificates/canada",
      "/postgraduate-certificates/australia",
      "/postgraduate-certificates/new-zealand",
      "/cpd",
      "/cpd/uk",
      "/cpd/europe",
      "/cpd/usa",
      "/cpd/australia",
      "/cpd/new-zealand",
      "/cpd/global",
      "/cpd/providers",
      "/cpd/providers/uk",
      "/cpd/providers/europe",
      "/cpd/providers/usa",
      "/cpd/providers/canada",
      "/cpd/providers/australia",
      "/cpd/providers/new-zealand",
      "/cpd/providers/global",
      "/resources",
      "/contact",
      "/countries",
      "/about",
      "/jobs",
      "/legal",
      "/search"
    ],
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage",
      "--disable-gpu"
    ],
    "concurrency": 2,
    "skipThirdPartyRequests": true,
    "minifyHtml": false
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@craco/craco": "^7.1.0",
    "@eslint/js": "9.23.0",
    "autoprefixer": "^10.4.20",
    "eslint": "9.23.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.4",
    "globals": "15.15.0",
    "postcss": "^8.4.49",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.17"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
